#include<stdio.h>

int main()
{
    int answer, score = 0;

    printf("Simple Quiz Game\n");

    printf("\n1. Capital of India?\n");
    printf("1.Delhi  2.Chennai  3.Mumbai\n");

    scanf("%d", &answer);

    if(answer == 1)
    {
        score++;
    }

    printf("\n2. 2 + 2 = ?\n");
    printf("1.3  2.4  3.5\n");

    scanf("%d", &answer);

    if(answer == 2)
    {
        score++;
    }

    printf("\nYour Score = %d", score);

    return 0;
}