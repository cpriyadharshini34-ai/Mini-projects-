#include<stdio.h>

int main()
{
    int units;
    float bill;

    printf("Enter electricity units: ");
    scanf("%d", &units);

    if(units <= 100)
    {
        bill = units * 1.5;
    }
    else if(units <= 300)
    {
        bill = units * 2.5;
    }
    else
    {
        bill = units * 4;
    }

    printf("\nElectricity Bill = %.2f", bill);

    return 0;
}