#include <stdio.h>

int main() {
    int m1, m2, m3, total;
    float average;

    printf("Enter marks for 3 subjects:\n");

    printf("Subject 1: ");
    scanf("%d", &m1);

    printf("Subject 2: ");
    scanf("%d", &m2);

    printf("Subject 3: ");
    scanf("%d", &m3);

    total = m1 + m2 + m3;
    average = total / 3.0;

    printf("\nTotal Marks = %d", total);
    printf("\nAverage = %.2f", average);

    if (average >= 90)
        printf("\nGrade: A");
    else if (average >= 75)
        printf("\nGrade: B");
    else if (average >= 50)
        printf("\nGrade: C");
    else
        printf("\nGrade: Fail");

    return 0;
}